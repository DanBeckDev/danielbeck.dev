---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/ui/Container.astro';
import { Icon } from 'astro-icon/components';
import { siteConfig } from '../consts/site';
import { ogImageUrl } from '../lib/seo';

const expertise = [
  'Frontend architecture at scale',
  'Micro-frontends & module federation',
  'Design systems & shared component libraries',
  'Developer experience, build tooling & bundlers',
  'AI-augmented engineering & autonomous agent systems',
  'TypeScript & web performance',
];

const facts = [
  { label: 'Role', value: siteConfig.role },
  { label: 'Now', value: 'NetBox Labs' },
  { label: 'Focus', value: 'Frontend platform · DX' },
  { label: 'Stack', value: 'TypeScript · React' },
];
---

<BaseLayout
  title="About"
  description={`About ${siteConfig.name}, a ${siteConfig.role.toLowerCase()} working on frontend architecture, design systems, and AI-augmented engineering.`}
  image={ogImageUrl('about')}
  type="profile"
>
  <Container width="wide">
    <div class="about">
      <div class="about__main">
        <p class="eyebrow mb-3">About</p>
        <h1 class="about__title">{siteConfig.name}</h1>

        <div class="prose about__bio">
          <p class="about__lead">
            I build platforms, products, and the tooling in between. My specialism is frontend
            architecture at scale: micro-frontends, design systems, shared component libraries, and
            the developer experience that ties them together.
          </p>
          <p>
            I'm a Senior Software Engineer at <strong>NetBox Labs</strong>, where I architect and
            maintain the frontend platform from the ground up. Before that I spent two years as a
            frontend consultant at <strong>Ensono Digital</strong>, delivering for clients including
            Next, the NHS, Gov.uk, and The Gym Group. The throughline is the same everywhere: make
            the right thing the easy thing for the engineers building on the platform.
          </p>
          <p>
            Lately I've been deep in the weeds of AI-augmented engineering. Not just using AI tools,
            but building autonomous agent systems that implement, test, and ship code across
            multiple repositories in parallel. It's changing how I think about what a single
            engineer can actually get done.
          </p>
          <p>
            I've given talks at meetups (including building a module bundler from scratch), appeared
            on podcasts, and mentored bootcamp graduates at the School of Code. I publish here and
            ship code on <a href={siteConfig.social.github}>GitHub</a>, building up an owned body of
            work rather than scattered posts on platforms I don't control.
          </p>

          <h2>What I work on</h2>
          <ul>
            {expertise.map((item) => <li>{item}</li>)}
          </ul>

          <h2>Elsewhere</h2>
          <p>
            Always up for a conversation about micro-frontends, design systems, or AI-driven
            development. Follow along via the <a href="/rss.xml">RSS feed</a>, see past
            <a href="/speaking/"> talks and podcasts</a>, or
            <a href="/contact/"> get in touch</a>.
          </p>
        </div>
      </div>

      <aside class="about__rail" aria-label="Quick facts">
        <dl class="facts">
          {
            facts.map((f) => (
              <div class="facts__row">
                <dt>{f.label}</dt>
                <dd>{f.value}</dd>
              </div>
            ))
          }
        </dl>
        <div class="about__links">
          <a href={siteConfig.social.github} target="_blank" rel="noopener noreferrer">
            <Icon name="simple-icons:github" aria-hidden="true" /> GitHub
          </a>
          <a href={siteConfig.social.linkedin} target="_blank" rel="noopener noreferrer">
            <Icon name="simple-icons:linkedin" aria-hidden="true" /> LinkedIn
          </a>
          <a href={siteConfig.social.youtube} target="_blank" rel="noopener noreferrer">
            <Icon name="simple-icons:youtube" aria-hidden="true" /> YouTube
          </a>
          <a href={siteConfig.social.x} target="_blank" rel="noopener noreferrer">
            <Icon name="simple-icons:x" aria-hidden="true" /> X
          </a>
          <a href={`mailto:${siteConfig.email}`}>
            <Icon name="lucide:mail" aria-hidden="true" />
            {siteConfig.email}
          </a>
        </div>
      </aside>
    </div>
  </Container>
</BaseLayout>

<style>
  .about {
    display: grid;
    gap: 3rem;
    padding-top: 3.5rem;
    padding-bottom: 5rem;
    grid-template-columns: 1fr;
  }
  .about__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 2.75rem);
    font-weight: 500;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
  }
  .about__lead {
    font-family: var(--font-display);
    font-size: 1.3rem;
    line-height: 1.5;
    color: var(--color-ink);
  }
  .facts {
    margin: 0;
    border: 1px solid var(--color-line);
    border-radius: 0.7rem;
    overflow: hidden;
  }
  .facts__row {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.7rem 1rem;
    border-bottom: 1px solid var(--color-line-soft);
    font-size: 0.85rem;
  }
  .facts__row:last-child {
    border-bottom: 0;
  }
  .facts dt {
    color: var(--color-faint);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .facts dd {
    margin: 0;
    color: var(--color-ink);
    text-align: right;
  }
  .about__links {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    margin-top: 1.25rem;
  }
  .about__links a {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
    color: var(--color-muted);
    text-decoration: none;
  }
  .about__links a:hover {
    color: var(--color-accent);
  }
  .about__links :global(svg) {
    width: 1rem;
    height: 1rem;
  }

  @media (min-width: 1024px) {
    .about {
      grid-template-columns: 1fr 18rem;
    }
    .about__rail {
      position: sticky;
      top: 5.5rem;
      align-self: start;
    }
  }
</style>
