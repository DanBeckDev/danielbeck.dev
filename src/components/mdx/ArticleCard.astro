---
import type { Post } from '../../lib/content';
import { postUrl, readingTime } from '../../lib/content';
import { formatDateShort, isoDate } from '../../lib/date';

interface Props {
  post: Post;
}

const { post } = Astro.props;
const { title, description, pubDate, category, tags } = post.data;
const minutes = readingTime(post.body);
---

<article class="card">
  <a class="card__link" href={postUrl(post.id)}>
    <div class="card__meta">
      <time datetime={isoDate(pubDate)}>{formatDateShort(pubDate)}</time>
      <span class="card__dot" aria-hidden="true">·</span>
      <span>{minutes} min read</span>
      <span class="card__dot" aria-hidden="true">·</span>
      <span class="card__cat">{category}</span>
    </div>
    <h3 class="card__title">{title}</h3>
    <p class="card__desc">{description}</p>
  </a>
  {
    tags.length > 0 && (
      <ul class="card__tags">
        {tags.slice(0, 4).map((tag) => (
          <li>{tag}</li>
        ))}
      </ul>
    )
  }
</article>

<style>
  .card {
    position: relative;
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--color-line-soft);
  }
  .card__link {
    display: block;
    text-decoration: none;
    color: inherit;
  }
  .card__meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-faint);
  }
  .card__cat {
    color: var(--color-accent);
  }
  .card__dot {
    opacity: 0.5;
  }
  .card__title {
    margin: 0.4rem 0 0.3rem;
    font-size: 1.2rem;
    font-weight: 600;
    line-height: 1.3;
    transition: color 0.15s ease;
  }
  .card:hover .card__title {
    color: var(--color-accent);
  }
  .card__desc {
    margin: 0;
    color: var(--color-muted);
    font-size: 0.95rem;
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin: 0.7rem 0 0;
    padding: 0;
    list-style: none;
  }
  .card__tags li {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--color-faint);
    padding: 0.1rem 0.45rem;
    border: 1px solid var(--color-line-soft);
    border-radius: 4px;
  }
</style>
