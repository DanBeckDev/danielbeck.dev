---
import { Icon } from 'astro-icon/components';
import { navItems, siteConfig } from '../../consts/site';
import Container from '../ui/Container.astro';

const year = new Date().getFullYear();

const socials = [
  { label: 'GitHub', href: siteConfig.social.github, icon: 'simple-icons:github' },
  { label: 'LinkedIn', href: siteConfig.social.linkedin, icon: 'simple-icons:linkedin' },
  { label: 'YouTube', href: siteConfig.social.youtube, icon: 'simple-icons:youtube' },
  { label: 'X', href: siteConfig.social.x, icon: 'simple-icons:x' },
  { label: 'Email', href: `mailto:${siteConfig.email}`, icon: 'lucide:mail' },
  { label: 'RSS', href: '/rss.xml', icon: 'lucide:rss' },
];
---

<footer class="footer">
  <Container width="wide">
    <div class="footer__inner">
      <div class="footer__brand">
        <a href="/" class="wordmark"
          >daniel<span class="wordmark__accent">beck</span><span class="wordmark__tld">.dev</span
          ></a
        >
        <p class="footer__tagline">{siteConfig.tagline}</p>
      </div>

      <nav class="footer__nav" aria-label="Footer">
        {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
        <a href="/contact/">Contact</a>
      </nav>

      <ul class="footer__social">
        {
          socials.map((s) => (
            <li>
              <a
                href={s.href}
                aria-label={s.label}
                {...(s.href.startsWith('http')
                  ? { target: '_blank', rel: 'noopener noreferrer' }
                  : {})}
              >
                <Icon name={s.icon} aria-hidden="true" />
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </Container>

  <Container width="wide">
    <div class="footer__bar">
      <p>© {year} {siteConfig.name}</p>
      <p>
        Built with <a href="https://astro.build" target="_blank" rel="noopener noreferrer">Astro</a>
      </p>
    </div>
  </Container>
</footer>

<style>
  .footer {
    margin-top: 4rem;
    border-top: 1px solid var(--color-line-soft);
    padding-top: 3rem;
    padding-bottom: 1.5rem;
  }
  .footer__inner {
    display: grid;
    gap: 2rem;
    grid-template-columns: 1fr;
  }
  .footer__brand .wordmark {
    font-family: var(--font-mono);
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-ink);
    text-decoration: none;
  }
  .wordmark__accent {
    color: var(--color-accent);
  }
  .wordmark__tld {
    color: var(--color-faint);
  }
  .footer__tagline {
    margin: 0.5rem 0 0;
    font-size: 0.85rem;
    color: var(--color-faint);
  }
  .footer__nav {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem 1.5rem;
  }
  .footer__nav a {
    font-size: 0.88rem;
    color: var(--color-muted);
    text-decoration: none;
  }
  .footer__nav a:hover {
    color: var(--color-accent);
  }
  .footer__social {
    display: flex;
    gap: 0.5rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .footer__social a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 0.5rem;
    color: var(--color-faint);
  }
  .footer__social a:hover {
    color: var(--color-accent);
    background-color: var(--color-elevated);
  }
  .footer__social :global(svg) {
    width: 1.15rem;
    height: 1.15rem;
  }
  .footer__bar {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 0.5rem;
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-line-soft);
    font-size: 0.8rem;
    color: var(--color-faint);
  }
  .footer__bar a {
    color: var(--color-muted);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  @media (min-width: 768px) {
    .footer__inner {
      grid-template-columns: 1.5fr 1fr auto;
      align-items: start;
    }
    .footer__social {
      justify-content: flex-end;
    }
  }
</style>
