---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/ui/PageHeader.astro';
import Container from '../components/ui/Container.astro';
import ProjectCard from '../components/mdx/ProjectCard.astro';
import { getProjects } from '../lib/content';
import { enrichProjects } from '../lib/github';
import { ogImageUrl } from '../lib/seo';

const projects = await getProjects();
const stars = await enrichProjects(projects);
---

<BaseLayout
  title="Open Source"
  description="Open-source projects by Daniel Beck — infrastructure, network automation, and cloud-native tooling, each tied to the writing and videos that explain it."
  image={ogImageUrl('open-source')}
>
  <PageHeader
    eyebrow="Open Source"
    title="Open Source"
    lead="Tools and reference implementations I build in the open. Most pair with a deep-dive article and a walkthrough video."
  />

  <Container width="wide" class="pb-20">
    {
      projects.length === 0 ? (
        <p class="empty">Projects coming soon.</p>
      ) : (
        <div class="grid">
          {projects.map((project) => (
            <ProjectCard
              project={project}
              stars={stars.get(project.id)?.stars}
              forks={stars.get(project.id)?.forks}
            />
          ))}
        </div>
      )
    }
  </Container>
</BaseLayout>

<style>
  .grid {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: 1fr;
  }
  @media (min-width: 640px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 1024px) {
    .grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .empty {
    color: var(--color-muted);
  }
</style>
