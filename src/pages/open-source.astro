---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/ui/PageHeader.astro';
import Container from '../components/ui/Container.astro';
import ContributionCard from '../components/opensource/ContributionCard.astro';
import { getContributions, totalMergedPRs } from '../lib/contributions';
import { siteConfig } from '../consts/site';
import { ogImageUrl } from '../lib/seo';

const contributions = await getContributions();
const totalPRs = totalMergedPRs(contributions);
const repoCount = contributions.length;
---

<BaseLayout
  title="Open Source"
  description="Open-source contributions by Daniel Beck: merged pull requests to the external libraries he builds on, from Partytown to Module Federation."
  image={ogImageUrl('open-source')}
>
  <PageHeader
    eyebrow="Open Source"
    title="Open Source Contributions"
    lead="I give back to the libraries I build on. These are merged pull requests to external open-source projects, pulled live from GitHub."
  >
    {
      totalPRs > 0 && (
        <p class="stats">
          <span>{totalPRs}</span> merged PRs across <span>{repoCount}</span>{' '}
          {repoCount === 1 ? 'project' : 'projects'}
        </p>
      )
    }
  </PageHeader>

  <Container width="content" class="pb-20">
    <div class="contrib-list">
      {contributions.map((contribution) => <ContributionCard contribution={contribution} />)}
    </div>

    <p class="profile">
      More on{' '}
      <a href={siteConfig.social.github} target="_blank" rel="noopener noreferrer">
        github.com/{siteConfig.githubUsername}
      </a>
    </p>
  </Container>
</BaseLayout>

<style>
  .stats {
    margin-top: 1.25rem;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-faint);
  }
  .stats span {
    color: var(--color-accent);
    font-weight: 500;
  }
  .contrib-list {
    display: grid;
    gap: 1.25rem;
  }
  .profile {
    margin-top: 2rem;
    font-size: 0.9rem;
    color: var(--color-muted);
  }
  .profile a {
    color: var(--color-accent);
    text-decoration: none;
  }
  .profile a:hover {
    text-decoration: underline;
    text-underline-offset: 2px;
  }
</style>
