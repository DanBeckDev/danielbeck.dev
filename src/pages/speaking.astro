---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/ui/PageHeader.astro';
import Container from '../components/ui/Container.astro';
import TalkCard from '../components/speaking/TalkCard.astro';
import { Icon } from 'astro-icon/components';
import { getSpeaking } from '../lib/content';
import { ogImageUrl } from '../lib/seo';

const talks = await getSpeaking();
const topics = ['Network Automation', 'Kubernetes & Platform Engineering', 'Production Reliability'];
---

<BaseLayout
  title="Speaking"
  description="Daniel Beck speaks on infrastructure, Kubernetes, network automation, and production engineering — talks, podcasts, and workshops."
  image={ogImageUrl('speaking')}
>
  <PageHeader
    eyebrow="Speaking"
    title="Speaking"
    lead="Available for conference talks, podcasts, and workshops on infrastructure, Kubernetes, network automation, and what it takes to keep systems reliable in production."
  >
    <div class="cta">
      <a class="cta__btn" href="/contact/">
        <Icon name="lucide:mail" aria-hidden="true" /> Invite me to speak
      </a>
      <ul class="cta__topics" aria-label="Topics I speak on">
        {topics.map((t) => <li>{t}</li>)}
      </ul>
    </div>
  </PageHeader>

  <Container width="content" class="pb-20">
    {
      talks.length === 0 ? (
        <p class="empty">
          No talks scheduled yet — this is where past and upcoming appearances will live.
        </p>
      ) : (
        <div class="timeline">
          {talks.map((talk) => (
            <TalkCard talk={talk} />
          ))}
        </div>
      )
    }
  </Container>
</BaseLayout>

<style>
  .cta {
    margin-top: 1.75rem;
  }
  .cta__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.55rem 1.05rem;
    border-radius: 0.55rem;
    background-color: var(--color-accent);
    color: var(--color-on-accent);
    font-weight: 600;
    font-size: 0.92rem;
    text-decoration: none;
  }
  .cta__btn:hover {
    background-color: var(--color-accent-soft);
  }
  .cta__btn :global(svg) {
    width: 1rem;
    height: 1rem;
  }
  .cta__topics {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.25rem;
    margin: 1.5rem 0 0;
    padding: 0;
    list-style: none;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--color-faint);
  }
  .cta__topics li {
    position: relative;
    padding-left: 1rem;
  }
  .cta__topics li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    width: 5px;
    height: 5px;
    border-radius: 9999px;
    background-color: var(--color-accent);
    transform: translateY(-50%);
  }
  .timeline {
    margin-top: 1rem;
  }
  .empty {
    color: var(--color-muted);
  }
</style>
