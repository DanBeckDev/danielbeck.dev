---
interface Props {
  prevUrl?: string;
  nextUrl?: string;
  current: number;
  total: number;
}
const { prevUrl, nextUrl, current, total } = Astro.props;
---

{
  total > 1 && (
    <nav class="pagination" aria-label="Pagination">
      {prevUrl ? (
        <a href={prevUrl} rel="prev">
          ← Newer
        </a>
      ) : (
        <span class="is-disabled">← Newer</span>
      )}
      <span class="pagination__count">
        Page {current} of {total}
      </span>
      {nextUrl ? (
        <a href={nextUrl} rel="next">
          Older →
        </a>
      ) : (
        <span class="is-disabled">Older →</span>
      )}
    </nav>
  )
}

<style>
  .pagination {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-line-soft);
    font-size: 0.9rem;
  }
  .pagination a {
    color: var(--color-ink);
    text-decoration: none;
    font-weight: 500;
  }
  .pagination a:hover {
    color: var(--color-accent);
  }
  .pagination .is-disabled {
    color: var(--color-faint);
    opacity: 0.5;
  }
  .pagination__count {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--color-faint);
  }
</style>
