---
/** Static, decorative service-topology SVG for the hero. Subtle, low-opacity,
 *  no animation by default (a one-time edge fade respects reduced-motion). */
---

<svg
  class="node-graph"
  viewBox="0 0 320 260"
  fill="none"
  aria-hidden="true"
  role="presentation"
  preserveAspectRatio="xMidYMid meet"
>
  <g class="node-graph__edges" stroke="currentColor" stroke-width="1">
    <line x1="60" y1="60" x2="160" y2="40" />
    <line x1="160" y1="40" x2="260" y2="70" />
    <line x1="60" y1="60" x2="110" y2="150" />
    <line x1="160" y1="40" x2="170" y2="130" />
    <line x1="260" y1="70" x2="240" y2="160" />
    <line x1="110" y1="150" x2="170" y2="130" />
    <line x1="170" y1="130" x2="240" y2="160" />
    <line x1="110" y1="150" x2="150" y2="220" />
    <line x1="240" y1="160" x2="200" y2="220" />
    <line x1="150" y1="220" x2="200" y2="220" />
  </g>
  <g class="node-graph__nodes">
    <circle cx="60" cy="60" r="5" />
    <circle cx="160" cy="40" r="6" class="is-accent" />
    <circle cx="260" cy="70" r="5" />
    <circle cx="110" cy="150" r="5" />
    <circle cx="170" cy="130" r="7" class="is-accent" />
    <circle cx="240" cy="160" r="5" />
    <circle cx="150" cy="220" r="5" />
    <circle cx="200" cy="220" r="5" class="is-accent" />
  </g>
</svg>

<style>
  .node-graph {
    width: 100%;
    height: auto;
    color: var(--color-line);
  }
  .node-graph__edges line {
    stroke-dasharray: 3 4;
    opacity: 0.8;
  }
  .node-graph__nodes circle {
    fill: var(--color-faint);
  }
  .node-graph__nodes circle.is-accent {
    fill: var(--color-accent);
  }

  @media (prefers-reduced-motion: no-preference) {
    .node-graph__edges line {
      stroke-dashoffset: 14;
      animation: dash 1.1s ease forwards;
    }
    @keyframes dash {
      to {
        stroke-dashoffset: 0;
      }
    }
  }
</style>
