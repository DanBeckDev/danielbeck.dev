{
  "project": "danielbeck.dev",
  "purpose": "Machine-readable map for AI agents and tooling.",
  "read_first": [
    "docs/README.md",
    "docs/ai-agent-guide.md",
    "docs/content/blog-agent-playbook.md",
    "docs/writing/blog-agent-rules.md",
    "docs/writing/technical-blog-quality.md",
    "docs/writing/blog-editing-loop.md",
    "docs/writing/voice-and-tone.md",
    "docs/architecture/content-model.md",
    "docs/architecture/styling.md"
  ],
  "source_of_truth": {
    "identity": "src/consts/site.ts",
    "navigation": "src/consts/site.ts",
    "categories": "src/consts/categories.ts",
    "tracked_repos": "src/consts/contributions.ts",
    "content_schemas": "src/content.config.ts",
    "blog_posts": "src/content/blog/*.mdx",
    "videos": "src/data/videos.yaml",
    "youtube_packages": "docs/content/youtube-scripts/*/",
    "speaking": "src/content/speaking/*.md",
    "global_styles": "src/styles/global.css"
  },
  "commands": {
    "dev": "npm run dev",
    "check": "npm run check",
    "build": "npm run build",
    "format": "npm run format"
  },
  "blog_guidance": {
    "playbook": "docs/content/blog-agent-playbook.md",
    "rules": "docs/writing/blog-agent-rules.md",
    "quality": "docs/writing/technical-blog-quality.md",
    "editing_loop": "docs/writing/blog-editing-loop.md",
    "post_doc": "docs/content/blog-posts.md",
    "scheduling_doc": "docs/content/scheduling-posts.md"
  },
  "video_guidance": {
    "youtube_scripts": "docs/content/youtube-scripts/README.md",
    "videos_doc": "docs/content/videos-and-speaking.md"
  },
  "rules": [
    "No em dashes or en dashes in visible copy.",
    "Identity lives only in src/consts/site.ts.",
    "Content belongs in collections and data files, not templates.",
    "Run npm run check before committing."
  ]
}
