---
import { Icon } from 'astro-icon/components';

interface Props {
  displayName: string;
  description: string;
  repoUrl: string;
  homepageUrl?: string;
  tech?: string[];
  status?: 'active' | 'maintained' | 'archived' | 'experimental';
  stars?: number;
  forks?: number;
  id?: string;
}

const {
  displayName,
  description,
  repoUrl,
  homepageUrl,
  tech = [],
  status,
  stars,
  forks,
  id,
} = Astro.props;

const statusLabel: Record<string, string> = {
  active: 'Active',
  maintained: 'Maintained',
  archived: 'Archived',
  experimental: 'Experimental',
};
---

<article class="proj" id={id}>
  <header class="proj__head">
    <h3 class="proj__name">{displayName}</h3>
    {
      status && (
        <span class="proj__status" data-status={status}>
          {statusLabel[status]}
        </span>
      )
    }
  </header>
  <p class="proj__desc">{description}</p>

  {
    tech.length > 0 && (
      <ul class="proj__tech">
        {tech.map((t) => (
          <li>{t}</li>
        ))}
      </ul>
    )
  }

  <div class="proj__links">
    <a href={repoUrl} target="_blank" rel="noopener noreferrer">
      <Icon name="simple-icons:github" aria-hidden="true" /> Repository
    </a>
    {
      homepageUrl && (
        <a href={homepageUrl} target="_blank" rel="noopener noreferrer">
          <Icon name="lucide:external-link" aria-hidden="true" /> Site
        </a>
      )
    }
    {
      typeof stars === 'number' && stars > 0 && (
        <span class="proj__stat">
          <Icon name="lucide:star" aria-hidden="true" /> {stars.toLocaleString('en-US')}
        </span>
      )
    }
    {
      typeof forks === 'number' && forks > 0 && (
        <span class="proj__stat">
          <Icon name="lucide:git-fork" aria-hidden="true" /> {forks.toLocaleString('en-US')}
        </span>
      )
    }
  </div>
</article>

<style>
  .proj {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 1.25rem;
    border: 1px solid var(--color-line);
    border-radius: 0.7rem;
    background-color: var(--color-surface);
    scroll-margin-top: 6rem;
  }
  .proj__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }
  .proj__name {
    margin: 0;
    font-size: 1.1rem;
  }
  .proj__status {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.12rem 0.5rem;
    border-radius: 9999px;
    border: 1px solid var(--color-line);
    color: var(--color-faint);
  }
  .proj__status[data-status='active'] {
    color: var(--color-tip);
    border-color: color-mix(in oklab, var(--color-tip) 40%, transparent);
  }
  .proj__status[data-status='experimental'] {
    color: var(--color-warning);
    border-color: color-mix(in oklab, var(--color-warning) 40%, transparent);
  }
  .proj__desc {
    margin: 0.6rem 0 0;
    color: var(--color-muted);
    font-size: 0.92rem;
    line-height: 1.6;
  }
  .proj__tech {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin: 0.85rem 0 0;
    padding: 0;
    list-style: none;
  }
  .proj__tech li {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--color-muted);
    padding: 0.1rem 0.45rem;
    border: 1px solid var(--color-line-soft);
    border-radius: 4px;
  }
  .proj__links {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem;
    margin-top: auto;
    padding-top: 1rem;
    font-size: 0.82rem;
  }
  .proj__links a {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    color: var(--color-muted);
    text-decoration: none;
  }
  .proj__links a:hover {
    color: var(--color-accent);
  }
  .proj__stat {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    color: var(--color-faint);
  }
  .proj__links :global(svg) {
    width: 0.9rem;
    height: 0.9rem;
  }
</style>
