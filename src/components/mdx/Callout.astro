---
import { Icon } from 'astro-icon/components';

interface Props {
  type?: 'note' | 'tip' | 'warning' | 'danger';
  title?: string;
}

const { type = 'note', title } = Astro.props;

const icons = {
  note: 'lucide:info',
  tip: 'lucide:lightbulb',
  warning: 'lucide:triangle-alert',
  danger: 'lucide:octagon-alert',
} as const;

const labels = { note: 'Note', tip: 'Tip', warning: 'Warning', danger: 'Danger' } as const;
---

<aside class="callout not-prose" data-type={type} role="note">
  <Icon name={icons[type]} class="callout__icon" aria-hidden="true" />
  <div class="callout__body">
    <p class="callout__title">{title ?? labels[type]}</p>
    <div class="callout__content"><slot /></div>
  </div>
</aside>

<style>
  .callout {
    --hue: var(--color-note);
    display: flex;
    gap: 0.75rem;
    margin: 1.75rem 0;
    padding: 0.95rem 1.1rem;
    border: 1px solid color-mix(in oklab, var(--hue) 38%, transparent);
    border-left-width: 3px;
    border-radius: 0.55rem;
    background-color: color-mix(in oklab, var(--hue) 9%, var(--color-base));
  }
  .callout[data-type='tip'] {
    --hue: var(--color-tip);
  }
  .callout[data-type='warning'] {
    --hue: var(--color-warning);
  }
  .callout[data-type='danger'] {
    --hue: var(--color-danger);
  }
  .callout__icon {
    flex: none;
    width: 1.2rem;
    height: 1.2rem;
    margin-top: 0.15rem;
    color: var(--hue);
  }
  .callout__body {
    min-width: 0;
  }
  .callout__title {
    margin: 0 0 0.2rem;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: color-mix(in oklab, var(--hue) 70%, var(--color-ink));
  }
  .callout__content {
    color: var(--color-muted);
    font-size: 0.95rem;
    line-height: 1.65;
  }
  .callout__content :global(> :first-child) {
    margin-top: 0;
  }
  .callout__content :global(> :last-child) {
    margin-bottom: 0;
  }
</style>
